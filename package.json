{
  "name": "sendevia-website",
  "private": true,
  "version": "26.6.452",
  "scripts": {
    "update-version": "bash ./scripts/update-version.sh",
    "docs:dev": "vitepress dev --host",
    "docs:build": "vitepress build",
    "docs:build-cf": "git fetch --unshallow && vitepress build",
    "docs:preview": "vitepress preview",
    "lint": "stylelint --fix \".vitepress/theme/styles/**/*.scss\" && eslint . --fix && prettier --write --log-level=warn .",
    "lint:style": "stylelint --fix \".vitepress/theme/styles/**/*.scss\"",
    "format": "prettier --write --log-level=warn ."
  },
  "dependencies": {
    "@material/material-color-utilities": "0.4",
    "pinia": "^3",
    "vue": "^3"
  },
  "devDependencies": {
    "@mdit/plugin-align": "^1",
    "@mdit/plugin-footnote": "^1",
    "@mdit/plugin-img-mark": "^1",
    "@mdit/plugin-tab": "^1",
    "@mdit/plugin-tasklist": "^1",
    "@types/node": "^24",
    "@vueuse/core": "^14",
    "eslint": "^10",
    "eslint-config-prettier": "^10",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-vue": "^10",
    "markdown-it-mathjax3": "^4",
    "prettier": "^3",
    "sass-embedded": "^1",
    "stylelint": "^17",
    "stylelint-config-standard-scss": "^17",
    "stylelint-order": "^8",
    "typescript": "^6",
    "typescript-eslint": "^8",
    "vitepress": "2.0.0-alpha.18",
    "vue-eslint-parser": "^10",
    "vue-tsc": "^3"
  }
}
